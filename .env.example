# =============================================================
#  data-hub — Variables de Entorno (Monorepo)
#  Copia este archivo como .env y ajusta los valores para tu
#  entorno local.  NUNCA comitas el .env real a git.
# =============================================================

# ── Base de Datos ─────────────────────────────────────────────
POSTGRES_DB=datahub
POSTGRES_USER=datahub_user
POSTGRES_PASSWORD=changeme_db

# URL usada por Spring Boot (referencia las vars de arriba)
DB_HOST=db
DB_PORT=5432
DB_NAME=${POSTGRES_DB}
DB_USERNAME=${POSTGRES_USER}
DB_PASSWORD=${POSTGRES_PASSWORD}

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=changeme_jwt_secret_at_least_256_bits_long_for_hs256
JWT_EXPIRATION_MS=3600000

# ── Spring Boot / Backend ─────────────────────────────────────
SPRING_PROFILES_ACTIVE=docker
APP_PORT=8080
# Tamaño máximo de archivo permitido (subida de Excel)
MAX_FILE_SIZE=50MB
MAX_REQUEST_SIZE=52MB
# Directorio de almacenamiento de archivos dentro del contenedor
FILES_STORAGE_PATH=/app/files

# ── Frontend (Vite) ───────────────────────────────────────────
# VITE_ es el prefijo que Vite expone al navegador
VITE_API_BASE_URL=http://localhost:${APP_PORT}
FRONTEND_PORT=5173

# ── Rate limiting (API pública) ───────────────────────────────
RATE_LIMIT_REQUESTS_PER_MINUTE=100

# ── Worker / Scheduler ────────────────────────────────────────
JOB_SCHEDULER_FIXED_DELAY_MS=2000
JOB_ORPHAN_TIMEOUT_MINUTES=10
