# =============================================================
#  erp-sync — Variables de Entorno
#  Copia este archivo como .env y ajusta los valores.
#  NUNCA commitas el .env real a git.
#
#  Este servicio usa su PROPIA base de datos PostgreSQL,
#  completamente separada del backend Spring Boot (data-hub).
# =============================================================

# ── Servidor ──────────────────────────────────────────────────
ERP_SYNC_PORT=3001
NODE_ENV=development

# ── CORS ─────────────────────────────────────────────────────
# Origen permitido para el frontend React.
CORS_ORIGIN=http://localhost:5173

# ── Base de Datos propia (erp-sync-db) ───────────────────────
# BD completamente separada de la BD del backend (data-hub).
# En docker-compose usa el hostname del servicio: erp-sync-db
# En local standalone usa localhost con el puerto 5433.
ERP_SYNC_DB_HOST=localhost
ERP_SYNC_DB_PORT=5433
ERP_SYNC_DB_NAME=erpsync
ERP_SYNC_DB_USER=erpsync_user
ERP_SYNC_DB_PASSWORD=changeme_erpsync_db
ERP_SYNC_DB_POOL_MAX=10

# ── ERPNext (configurar también vía tabla erpsync_params) ─────
# Estos valores arrancan la seed de erpsync_params.
# Una vez en BD, los cambios se hacen directamente en la tabla.
#
# ERPSYNC_ERP_BASE_URL → URL base de ERPNext, ej: http://192.168.1.74:9999
# ERPSYNC_ERP_AUTH     → Header Authorization, ej: Basic dXNlcjpwYXNz
#
# El scheduler NO sincronizará hasta que ERPSYNC_ERP_BASE_URL
# y ERPSYNC_ERP_AUTH estén configurados en erpsync_params.
