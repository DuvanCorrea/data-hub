# =============================================================
#  erp-sync — Variables de Entorno
#  Copia este archivo como .env y ajusta los valores.
#  NUNCA commitas el .env real a git.
# =============================================================

# ── Base de datos (misma BD que el backend principal) ─────────
# Se usan las mismas variables del docker-compose raíz.
# En standalone, configurar manualmente:
DB_HOST=localhost
DB_PORT=5432
DB_NAME=datahub
DB_USERNAME=datahub_user
DB_PASSWORD=changeme_db
DB_POOL_MAX=10

# ── Servidor ──────────────────────────────────────────────────
ERP_SYNC_PORT=3001
NODE_ENV=development

# ── CORS ─────────────────────────────────────────────────────
# Origen permitido para el frontend React. Usar * para permitir todos.
CORS_ORIGIN=http://localhost:5173

# ── ERPNext (también configurables vía tabla erpsync_params) ──
# Estos valores se usan como semilla; la tabla erpsync_params
# tiene prioridad una vez que el servicio arrancó.
# Los parámetros en BD se actualizan vía PUT /admin/params (futuro)
# o directamente en la tabla erpsync_params.
#
# ERPSYNC_ERP_BASE_URL  → URL base de ERPNext, ej: http://192.168.1.74:9999
# ERPSYNC_ERP_AUTH      → Header Authorization, ej: Basic dXNlcjpwYXNz
#
# Nota: estos dos NO tienen valor por defecto. El scheduler no
# correrá hasta que estén configurados en erpsync_params.
