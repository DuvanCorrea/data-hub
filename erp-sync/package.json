{
  "name": "erp-sync",
  "version": "1.0.0",
  "description": "Microservicio de sincronización unidireccional hacia ERPNext",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --ext ts,sql --ignore 'dist/**' --exec tsx src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc",
    "start:compiled": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "node-cron": "^3.0.3",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.6",
    "nodemon": "^3.1.4",
    "tsx": "^4.15.7",
    "typescript": "^5.4.5"
  }
}
